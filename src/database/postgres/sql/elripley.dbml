// ================================================================
// ElRipley Database Schema - Complete Schema
// Generated from SQLAlchemy models
// Database: PostgreSQL
// ================================================================

// ================================================================
// USERS AND ROLES TABLES
// ================================================================

Table roles {
  id varchar(36) [pk]
  name varchar(50) [not null, unique, default: 'user']
}

Table users {
  id varchar(36) [pk]
  created_at integer [not null]
  updated_at integer [not null]
}

Table user_api_keys {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null]
  key_name varchar(100) // "My OpenAI Key", "Team Key"
  encrypted_key text [not null] // AES-256 encrypted API key
  key_prefix varchar(20) // "sk-proj-abc..." for display purposes
  provider varchar(50) [not null, default: 'openai'] // 'openai', 'anthropic', etc.
  is_active boolean [not null, default: true]
  settings jsonb // User preferences: model, reasoning effort, verbosity, etc.
  last_used_at bigint // Track last usage timestamp
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table user_role {
  user_id varchar(36) [pk]
  role_id varchar(36) [pk]
}

Table refresh_tokens {
  id varchar(36) [pk]
  user_id varchar(36) [not null]
  token varchar(512) [not null, unique] // JWT refresh token
  expires_at integer [not null] // Unix timestamp when token expires
  is_revoked boolean [not null, default: false] // For token rotation/revocation
  created_at integer [not null]
  updated_at integer [not null]
}

Table user_conversation_settings {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null, unique]
  context_token_limit integer // User's preferred context token limit
  context_buffer_percent integer // User's preferred buffer percentage (0-100)
  summarizer_model varchar(100) // User's preferred model for summarization
  vision_model varchar(100) // User's preferred model for vision tasks
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// ================================================================
// FACEBOOK INTEGRATION TABLES
// ================================================================

Table facebook_app_scope_users {
  id varchar(255) [pk] // ASID
  user_id varchar(36) [not null]
  name varchar(255)
  gender varchar(255)
  email varchar(255)
  picture varchar(255)
  created_at integer [not null]
  updated_at integer [not null]
}

Table fan_pages {
  id varchar(255) [pk] // page_id
  name varchar(1024)
  avatar varchar(1024)
  category varchar
  created_at integer [not null]
  updated_at integer [not null]
}

Table facebook_page_admins {
  id varchar(36) [pk]
  facebook_user_id varchar(255) [not null]
  page_id varchar(255) [not null]
  access_token text [not null] // page token
  tasks jsonb // e.g., ["MANAGE", "MESSAGING", "CREATE_CONTENT"]
  created_at integer [not null]
  updated_at integer [not null]
}

Table facebook_page_scope_users {
  id varchar(255) [pk] // PSID
  fan_page_id varchar(255) [not null]
  user_info jsonb
  created_at integer [not null]
  updated_at integer [not null]
}

// ================================================================
// POSTS AND COMMENTS TABLES
// ================================================================

Table posts {
  id varchar(255) [pk] // Facebook post_id
  fan_page_id varchar(255) [not null]
  message text // post text content
  video_link text // video URL if post contains video
  photo_link text // photo URL if post contains photo
  facebook_created_time integer // created_time from webhook
  // Engagement aggregate counts
  reaction_total_count integer [default: 0]
  reaction_like_count integer [default: 0]
  reaction_love_count integer [default: 0]
  reaction_haha_count integer [default: 0]
  reaction_wow_count integer [default: 0]
  reaction_sad_count integer [default: 0]
  reaction_angry_count integer [default: 0]
  reaction_care_count integer [default: 0]
  share_count integer [default: 0]
  comment_count integer [default: 0]
  // Additional metadata
  full_picture text // High-res image URL
  permalink_url text // Direct link to post
  status_type varchar(100) // mobile_status_update, added_photos, etc.
  is_published boolean [default: true]
  // Tracking timestamps
  reactions_fetched_at integer // When reactions were last fetched
  engagement_fetched_at integer // When full engagement was last fetched
  created_at integer [not null]
  updated_at integer [not null]
}

Table comments {
  id varchar(255) [pk] // Facebook comment_id
  post_id varchar(255) [not null]
  parent_comment_id varchar(255) // for reply comments, references another comment, if null, it is a top-level comment
  is_from_page boolean [not null, default: false] // TRUE if comment is from page itself
  fan_page_id varchar(255) [not null] // direct reference to fan page for performance
  facebook_page_scope_user_id varchar(255) // PSID if from user, NULL if from page
  message text // comment text content
  photo_url text // photo URL if comment contains photo
  video_url text // video URL if comment contains video
  facebook_created_time integer // created_time from webhook
  // Engagement counts
  like_count integer [default: 0]
  reply_count integer [default: 0]
  // Tracking timestamp
  reactions_fetched_at integer
  is_hidden boolean [not null, default: false] // for hiding comments without deleting
  page_seen_at integer // when page/admin viewed this comment (for per-comment tracking)
  deleted_at integer // soft delete timestamp, NULL if not deleted
  created_at integer [not null]
  updated_at integer [not null]
}

// ================================================================
// REACTIONS TABLES
// ================================================================

Table post_reactions {
  id uuid [pk, default: `gen_random_uuid()`]
  post_id varchar(255) [not null]
  fan_page_id varchar(255) [not null]
  // Reactor info
  reactor_id varchar(255) // Page-scoped user ID (PSID), NULL for page reactions
  reactor_name varchar(500) // User/Page display name, NULL for page reactions
  reactor_profile_pic text // Profile picture URL (optional)
  // Reaction details
  reaction_type varchar(20) [not null] // LIKE, LOVE, HAHA, WOW, SAD, ANGRY, CARE
  // Timestamps
  created_at integer [not null]
  updated_at integer [not null]
}

Table comment_reactions {
  id uuid [pk, default: `gen_random_uuid()`]
  comment_id varchar(255) [not null]
  post_id varchar(255) [not null]
  fan_page_id varchar(255) [not null]
  // Reactor info
  reactor_id varchar(255) // Page-scoped user ID (PSID), NULL for page reactions
  reactor_name varchar(500) // User/Page display name, NULL for page reactions
  // Reaction details
  reaction_type varchar(20) [not null]
  // Timestamps
  created_at integer [not null]
  updated_at integer [not null]
}

// ================================================================
// COMMENT CONVERSATIONS TABLES
// ================================================================

Table facebook_conversation_comments {
  id uuid [pk, default: `gen_random_uuid()`]
  root_comment_id varchar(255) [not null] // anchor comment id
  fan_page_id varchar(255) [not null]
  post_id varchar(255) [not null]
  participant_scope_users jsonb [not null, default: `'[]'::jsonb`] // list of participant snapshots keyed by facebook_page_scope_user_id
  has_page_reply boolean [not null, default: false]
  latest_comment_is_from_page boolean
  latest_comment_id varchar(255) // most recent comment in the thread
  latest_comment_facebook_time integer
  page_last_seen_comment_id varchar(255) // cursor: last comment page has seen
  page_last_seen_at integer // timestamp when page last viewed this thread
  mark_as_read boolean [not null, default: false] // user manually toggle read/unread state (UX feature)
  created_at integer [not null]
  updated_at integer [not null]
}

Table facebook_conversation_comment_entries {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null]
  comment_id varchar(255) [not null]
  is_root_comment boolean [not null, default: false]
  created_at integer [not null]
  updated_at integer [not null]
}

// ================================================================
// SYNC STATE TABLES
// ================================================================

Table facebook_post_sync_states {
  id serial [pk]
  fan_page_id varchar(255) [not null, unique]
  posts_cursor text // Facebook paging cursor (after)
  total_synced_posts integer [not null, default: 0]
  status varchar(50) [not null, default: 'idle'] // idle | in_progress | completed
  last_sync_at integer
  created_at integer [not null]
  updated_at integer [not null]
}

Table facebook_post_comment_sync_states {
  id serial [pk]
  post_id varchar(255) [not null, unique]
  fan_page_id varchar(255) [not null]
  comments_cursor text // Facebook paging cursor for root comments
  total_synced_root_comments integer [not null, default: 0]
  total_synced_comments integer [not null, default: 0] // Including replies
  status varchar(50) [not null, default: 'idle'] // idle | in_progress | completed
  last_sync_at integer
  created_at integer [not null]
  updated_at integer [not null]
}

// ================================================================
// MESSENGER CONVERSATIONS AND MESSAGES
// ================================================================

Table facebook_conversation_messages {
  id varchar(255) [pk] // native Graph conversation id (e.g., t_*)
  fan_page_id varchar(255) [not null]
  facebook_page_scope_user_id varchar(255) [not null]
  participants_snapshot jsonb [not null, default: `'[]'::jsonb`]
  latest_message_is_from_page boolean
  latest_message_id varchar(255)
  latest_message_facebook_time bigint
  page_last_seen_message_id varchar(255) // cursor: last message page has seen (app controls this)
  page_last_seen_at bigint
  user_seen_at bigint // timestamp when user saw conversation (from FB webhook, no specific message)
  mark_as_read boolean [not null, default: false] // user manually toggle read/unread state (UX feature)
  deleted_at integer // soft delete timestamp, NULL if not deleted
  created_at integer [not null]
  updated_at integer [not null]
}

Table messages {
  id varchar(255) [pk] // Facebook message_id (mid)
  conversation_id varchar(255) [not null] // references facebook_conversation_messages table
  is_echo boolean [not null, default: false] // TRUE if message from page, FALSE if from user
  text text // text content
  photo_url text // photo/image/gif/sticker URL
  video_url text // video URL
  audio_url text // audio URL
  template_data jsonb // for templates and interactive elements
  facebook_timestamp bigint // timestamp from webhook (milliseconds)
  page_seen_at bigint // when page saw this message (app controls, for per-message tracking)
  deleted_at integer // soft delete timestamp, NULL if not deleted
  created_at integer [not null]
  updated_at integer [not null]
}

Table facebook_inbox_sync_states {
  id serial [pk]
  fan_page_id varchar(255) [not null, unique]
  fb_cursor text // Facebook paging cursor (after cursor)
  total_synced_conversations integer [not null, default: 0]
  total_synced_messages integer [not null, default: 0]
  status varchar(50) [not null, default: 'idle'] // idle | in_progress | completed
  last_sync_at integer
  created_at integer [not null]
  updated_at integer [not null]
}

// ================================================================
// UNIFIED MEDIA ASSETS TABLES
// ================================================================

// Unified media assets table - tracks ALL media in S3: user uploads, Facebook mirrors, etc.
Table media_assets {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null] // Owner of this media (for quota tracking)
  
  // Source differentiation
  source_type varchar(20) [not null] // 'user_upload' | 'facebook_mirror'
  
  // Facebook mirror specific fields (NULL for user uploads)
  fb_owner_type varchar(50) // 'fan_page', 'page_scope_user', 'post', 'comment', 'message'
  fb_owner_id varchar(255) // ID of the FB entity that owns this media
  fb_field_name varchar(100) // Field/column name (e.g., 'avatar', 'photo_url', 'profile_pic')
  source_url text // Original Facebook URL
  source_hash varchar(64) // SHA256/ETag for deduplication
  
  // Core media info
  media_type varchar(20) [not null, default: 'image'] // image | video | audio
  s3_key varchar(500) [not null]
  s3_url text [not null]
  file_size_bytes bigint [not null, default: 0] // For quota tracking
  mime_type varchar(100) // e.g., 'image/jpeg', 'video/mp4'
  original_filename varchar(500) // Original filename (for user uploads)
  
  // Status & lifecycle
  status varchar(20) [not null, default: 'ready'] // pending | ready | failed
  error_message text
  retention_policy varchar(30) [not null, default: 'one_day'] // 'one_day' | 'one_week' | 'two_weeks' | 'one_month' | 'permanent'
  expires_at bigint // Epoch millis when asset expires (NULL for permanent)
  
  // AI-generated description (for fallback when media stale/expired)
  description text
  description_model varchar(100) // Model used to generate (e.g., 'gpt-4o-mini')
  description_generated_at bigint // When description was generated
  
  // Additional metadata
  metadata jsonb // Any additional data (dimensions, duration, etc.)
  last_checked_at bigint // Last S3 availability check
  
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// User storage quota tracking - only 'permanent' retention media counts toward quota
Table user_storage_quotas {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null, unique]
  
  // Current usage (bytes) - calculated from media_assets where retention_policy = 'permanent'
  permanent_storage_used_bytes bigint [not null, default: 0]
  
  // Storage limit (bytes) - default: 500MB
  permanent_storage_limit_bytes bigint [not null, default: 524288000]
  
  last_reconciled_at bigint // Last time quota was recalculated from actual media
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// Junction table: prompts <-> media assets (many-to-many)
Table suggest_response_prompt_media {
  id uuid [pk, default: `gen_random_uuid()`]
  
  // Polymorphic reference to prompt
  prompt_type varchar(30) [not null] // 'page_prompt' | 'page_scope_user_prompt'
  prompt_id uuid [not null]
  
  // Reference to media asset
  media_id uuid [not null]
  
  // Optional ordering for display
  display_order int [not null, default: 0]
  
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// Media attachments for memory_blocks
Table memory_block_media {
  id uuid [pk, default: `gen_random_uuid()`]
  block_id uuid [not null]
  media_id uuid [not null]
  display_order integer [not null, default: 1]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  
  Indexes {
    (block_id, media_id) [unique]
  }
}

// ================================================================
// BILLING CORE TABLES
// ================================================================

Table billing_settings {
  id uuid [pk, default: `gen_random_uuid()`]
  setting_key varchar(100) [not null, unique]
  setting_value decimal(10, 4) [not null]
  description text
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table user_credit_balance {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null, unique]
  balance_usd decimal(10, 4) [not null, default: 0]
  lifetime_earned_usd decimal(10, 4) [default: 0]
  lifetime_spent_usd decimal(10, 4) [default: 0]
  last_credited_at bigint
  last_spent_at bigint
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table credit_transactions {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null]
  transaction_type varchar(50) [not null] // 'welcome_bonus', 'topup', 'ai_usage', 'adjustment'
  amount_usd decimal(10, 4) [not null]
  balance_before_usd decimal(10, 4) [not null]
  balance_after_usd decimal(10, 4) [not null]
  source_type varchar(50) // 'stripe_payment', 'payos_payment', 'agent_response', 'manual_adjustment'
  source_id uuid
  description text
  metadata jsonb
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// ================================================================
// STRIPE INTEGRATION TABLES
// ================================================================

Table stripe_customers {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null, unique]
  stripe_customer_id varchar(255) [not null, unique]
  email varchar(255)
  name varchar(255)
  default_payment_method_id varchar(255)
  metadata jsonb
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table stripe_products {
  id uuid [pk, default: `gen_random_uuid()`]
  product_code varchar(50) [not null, unique]
  product_name varchar(100) [not null]
  product_type varchar(50) [not null, default: 'topup']
  amount_usd decimal(10, 2)
  credits_usd decimal(10, 4)
  stripe_product_id varchar(255) [not null]
  stripe_price_id varchar(255)
  is_active boolean [default: true]
  description text
  metadata jsonb
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table stripe_payments {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null]
  stripe_customer_id uuid [not null]
  stripe_payment_intent_id varchar(255)
  stripe_charge_id varchar(255)
  stripe_invoice_id varchar(255)
  stripe_product_id uuid
  amount_usd decimal(10, 2) [not null]
  credits_usd decimal(10, 4) [not null]
  currency varchar(3) [not null, default: 'usd']
  payment_method_type varchar(50)
  payment_method_last4 varchar(4)
  payment_method_brand varchar(50)
  status varchar(50) [not null]
  failure_code varchar(100)
  failure_message text
  refunded_amount_usd decimal(10, 2) [default: 0]
  refunded_at bigint
  metadata jsonb
  paid_at bigint
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table stripe_webhook_events {
  id uuid [pk, default: `gen_random_uuid()`]
  stripe_event_id varchar(255) [not null, unique]
  event_type varchar(100) [not null]
  api_version varchar(50)
  status varchar(50) [not null, default: 'pending']
  event_data jsonb [not null]
  stripe_customer_id varchar(255)
  stripe_payment_intent_id varchar(255)
  stripe_invoice_id varchar(255)
  user_id varchar(36)
  processed_at bigint
  error_message text
  retry_count integer [default: 0]
  last_retry_at bigint
  event_created_at bigint [not null]
  received_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// ================================================================
// SEPAY INTEGRATION TABLES (VND bank transfer via VietQR)
// ================================================================

Table sepay_config {
  id uuid [pk, default: `gen_random_uuid()`]
  config_key varchar(100) [not null, unique]
  config_value text [not null]
  description text
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table user_topup_codes {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null, unique]
  topup_code varchar(20) [not null, unique]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table sepay_transactions {
  id uuid [pk, default: `gen_random_uuid()`]
  sepay_id bigint [not null, unique]
  user_id varchar(36)
  gateway varchar(50) [not null]
  account_number varchar(50) [not null]
  amount_vnd bigint [not null]
  amount_usd decimal(10, 4)
  transfer_type varchar(10) [not null]
  content text
  reference_code varchar(100)
  transaction_date varchar(50)
  status varchar(50) [not null, default: 'unmatched']
