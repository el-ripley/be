  notes text
  processed_at bigint
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// ================================================================
// OPENAI INTEGRATION TABLES
// ================================================================

Table openai_conversation {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null]
  title varchar(500) // Optional conversation title
  current_branch_id uuid // Current active branch
  message_sequence_counter integer [not null, default: 0] // Counter for message sequence numbers
  oldest_message_id uuid // Reference to the oldest message in conversation
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table openai_message {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null]
  // Sequence number for ordering messages across all branches
  sequence_number integer [not null] // Global sequence within conversation for ordering
  // Message type determines which fields are relevant
  role varchar(50) [not null] // Recommended roles: 'system', 'developer', 'user', 'assistant', 'tool'
  type varchar(50) [not null] // Recommended types: 'message', 'reasoning', 'function_call', 'function_call_output', 'user_input'
  content jsonb // Content fields (for type='message' or 'user_input') - nullable
  metadata jsonb // Optional metadata for tagging message source or flags
  reasoning_summary jsonb // Reasoning fields (for type='reasoning') - nullable
  // For function_call and function_call_output
  call_id varchar(255) // Links function_call to function_call_output - nullable
  function_name varchar(255) // nullable
  function_arguments jsonb // Function arguments (for type='function_call') - nullable
  function_output jsonb // Function output (for type='function_call_output') - nullable
  // Status - nullable
  status varchar(50)
  // Timestamps
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table openai_conversation_branch {
  id uuid [pk, default: `gen_random_uuid()`]
  conversation_id uuid [not null]
  created_from_message_id uuid // Message tạo branch từ đó
  created_from_branch_id uuid // Branch cũ chứa message tạo branch
  message_ids uuid[] [not null, default: `'{}'`] // Array chứa message IDs theo thứ tự
  branch_name varchar(255) // Optional branch name
  is_active boolean [default: false] // Current active branch
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table openai_response {
  id uuid [pk, default: `gen_random_uuid()`]
  response_id varchar(255) [unique, not null] // OpenAI response ID
  // User and conversation context
  user_id varchar(36) [not null]
  conversation_id uuid
  // Branch tracking
  branch_id uuid
  // API Key tracking (BYOK support)
  api_key_type varchar(20) [not null, default: 'system'] // 'system' | 'user_byok'
  user_api_key_id uuid // Reference to user's BYOK key if used
  // Model & timing
  model varchar(100) [not null] // e.g., 'gpt-5-mini', 'gpt-4o'
  created_at bigint [not null] // OpenAI timestamp (milliseconds)
  latency_ms integer // Time taken for API call
  // Token usage (from response.usage)
  input_tokens integer [not null, default: 0]
  cached_tokens integer [default: 0] // For prompt caching
  output_tokens integer [not null, default: 0]
  reasoning_tokens integer [default: 0] // For reasoning models (o1)
  total_tokens integer [not null, default: 0]
  // Cost tracking (USD)
  input_cost decimal(10, 6) [default: 0]
  output_cost decimal(10, 6) [default: 0]
  total_cost decimal(10, 6) [default: 0]
  // Request/Response data (JSONB for flexibility)
  input jsonb // Full input messages/prompts
  output jsonb // Full response output
  tools jsonb // Tools used in this call
  metadata jsonb // Additional context
  // Status tracking
  status varchar(50) [not null] // 'completed', 'failed', 'in_progress'
  error jsonb // Error details if failed
  // Timestamps
  logged_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  agent_response_id uuid // Reference to agent_response
}

Table openai_branch_message_mapping {
  id uuid [pk, default: `gen_random_uuid()`]
  message_id uuid [not null]
  branch_id uuid [not null]
  is_modified boolean [default: false] // Message có bị modify trong branch này không
  modified_content jsonb // Nội dung đã modify (nếu có)
  modified_reasoning_summary jsonb // Reasoning summary đã modify (nếu có)
  modified_function_arguments jsonb // Function arguments đã modify (nếu có)
  modified_function_output jsonb // Function output đã modify (nếu có)
  is_hidden boolean [default: false] // Message có bị ẩn trong branch này không
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table agent_response {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null]
  conversation_id uuid // NULL for standalone agents (e.g., suggest_response_agent)
  branch_id uuid // NULL for standalone agents (e.g., suggest_response_agent)
  agent_type varchar(64) [not null, default: 'conversation_agent'] // Categorizes the agent execution
  message_ids uuid[] [not null, default: `'{}'`] // Array of message IDs generated in this agent response
  // API Key tracking (BYOK support)
  api_key_type varchar(20) [not null, default: 'system'] // 'system' | 'user_byok'
  user_api_key_id uuid // Reference to user's BYOK key if used
  // Aggregate fields
  model varchar(100) // Primary model used
  total_input_tokens integer [default: 0]
  total_output_tokens integer [default: 0]
  total_tokens integer [default: 0]
  total_latency_ms integer
  total_cost decimal(10, 6) [default: 0] // Aggregate cost of all openai_response in this agent execution
  call_count integer [default: 0] // Number of LLM calls
  status varchar(50) [not null, default: 'in_progress'] // 'completed' | 'failed' | 'partial' | 'in_progress'
  error jsonb
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// ================================================================
// SUGGEST RESPONSE TABLES
// ================================================================

Table suggest_response_agent {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null, unique]
  settings jsonb [default: `'{"model": "gpt-5.2", "reasoning": "low", "verbosity": "low"}'::jsonb`]
  allow_auto_suggest boolean [not null, default: false]
  num_suggest_response integer [not null, default: 3]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table page_memory {
  id uuid [pk, default: `gen_random_uuid()`]
  fan_page_id varchar(255) [not null]
  owner_user_id varchar(36) [not null]
  prompt_type varchar(20) [not null] // 'messages' | 'comments'
  created_by_type varchar(20) [not null] // 'user' | 'agent'
  is_active boolean [not null, default: true]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table page_scope_user_memory {
  id uuid [pk, default: `gen_random_uuid()`]
  fan_page_id varchar(255) [not null]
  facebook_page_scope_user_id varchar(255) [not null]
  owner_user_id varchar(36) [not null]
  created_by_type varchar(20) [not null] // 'user' | 'agent'
  is_active boolean [not null, default: true]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table user_memory {
  id uuid [pk, default: `gen_random_uuid()`]
  owner_user_id varchar(36) [not null]
  created_by_type varchar(20) [not null] // 'user' | 'agent'
  is_active boolean [not null, default: true]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

Table memory_blocks {
  id uuid [pk, default: `gen_random_uuid()`]
  prompt_type varchar(30) [not null] // 'page_prompt' | 'user_prompt' | 'user_memory'
  prompt_id uuid [not null]
  block_key varchar(100) [not null]
  title varchar(255) [not null]
  content text [not null]
  display_order integer [not null, default: 0]
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  created_by_type varchar(20) [not null] // 'user' | 'agent'
}

Table suggest_response_history {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id varchar(36) [not null]
  fan_page_id varchar(255) [not null]
  conversation_type varchar(20) [not null] // 'messages' | 'comments'
  facebook_conversation_messages_id varchar(255)
  facebook_conversation_comments_id uuid
  latest_item_id varchar(255) [not null]
  latest_item_facebook_time bigint [not null]
  page_prompt_id uuid // references page_memory.id
  page_scope_user_prompt_id uuid // references page_scope_user_memory.id
  suggestions jsonb [not null, default: `'[]'::jsonb`]
  suggestion_count integer [not null, default: 0]
  agent_response_id uuid [not null]
  trigger_type varchar(20) [not null] // 'user' | 'auto'
  selected_suggestion_index integer
  reaction varchar(20) // 'like' | 'dislike'
  created_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
  updated_at bigint [not null, default: `EXTRACT(EPOCH FROM NOW())::BIGINT * 1000`]
}

// ================================================================
// RELATIONSHIPS
// ================================================================

// Users Domain Relationships
Ref: user_api_keys.user_id > users.id [delete: cascade]
Ref: user_role.user_id > users.id [delete: cascade]
Ref: user_role.role_id > roles.id [delete: cascade]
Ref: refresh_tokens.user_id > users.id [delete: cascade]
Ref: user_conversation_settings.user_id > users.id [delete: cascade]

// Media Assets Relationships
Ref: media_assets.user_id > users.id [delete: cascade]
Ref: user_storage_quotas.user_id > users.id [delete: cascade]
Ref: suggest_response_prompt_media.media_id > media_assets.id [delete: cascade]
Ref: memory_block_media.block_id > memory_blocks.id [delete: cascade]
Ref: memory_block_media.media_id > media_assets.id [delete: cascade]

// Billing Relationships
Ref: user_credit_balance.user_id > users.id [delete: cascade]
Ref: credit_transactions.user_id > users.id [delete: cascade]

// Stripe Relationships
Ref: stripe_customers.user_id > users.id [delete: cascade]
Ref: stripe_payments.user_id > users.id [delete: cascade]
Ref: stripe_payments.stripe_customer_id > stripe_customers.id [delete: cascade]
Ref: stripe_payments.stripe_product_id > stripe_products.id [delete: set null]
Ref: stripe_webhook_events.user_id > users.id [delete: set null]

// SePay Relationships
Ref: user_topup_codes.user_id > users.id [delete: cascade]
Ref: sepay_transactions.user_id > users.id [delete: set null]

// Facebook Integration Relationships
Ref: facebook_app_scope_users.user_id > users.id [delete: cascade]
Ref: facebook_page_admins.facebook_user_id > facebook_app_scope_users.id [delete: cascade]
Ref: facebook_page_admins.page_id > fan_pages.id [delete: cascade]
Ref: facebook_page_scope_users.fan_page_id > fan_pages.id [delete: cascade]
Ref: posts.fan_page_id > fan_pages.id [delete: cascade]
Ref: comments.post_id > posts.id [delete: cascade]
Ref: comments.fan_page_id > fan_pages.id [delete: cascade]
Ref: comments.parent_comment_id > comments.id [delete: cascade]
Ref: comments.facebook_page_scope_user_id > facebook_page_scope_users.id [delete: set null]
Ref: post_reactions.post_id > posts.id [delete: cascade]
Ref: post_reactions.fan_page_id > fan_pages.id [delete: cascade]
Ref: comment_reactions.comment_id > comments.id [delete: cascade]
Ref: comment_reactions.post_id > posts.id [delete: cascade]
Ref: comment_reactions.fan_page_id > fan_pages.id [delete: cascade]
Ref: facebook_conversation_comments.root_comment_id > comments.id [delete: cascade]
Ref: facebook_conversation_comments.fan_page_id > fan_pages.id [delete: cascade]
Ref: facebook_conversation_comments.post_id > posts.id [delete: cascade]
Ref: facebook_conversation_comments.latest_comment_id > comments.id [delete: set null]
Ref: facebook_conversation_comments.page_last_seen_comment_id > comments.id [delete: set null]
Ref: facebook_conversation_comment_entries.conversation_id > facebook_conversation_comments.id [delete: cascade]
Ref: facebook_conversation_comment_entries.comment_id > comments.id [delete: cascade]
Ref: facebook_post_sync_states.fan_page_id > fan_pages.id [delete: cascade]
Ref: facebook_post_comment_sync_states.post_id > posts.id [delete: cascade]
Ref: facebook_post_comment_sync_states.fan_page_id > fan_pages.id [delete: cascade]
Ref: facebook_conversation_messages.fan_page_id > fan_pages.id [delete: cascade]
Ref: facebook_conversation_messages.facebook_page_scope_user_id > facebook_page_scope_users.id [delete: cascade]
Ref: messages.conversation_id > facebook_conversation_messages.id [delete: cascade]
Ref: facebook_inbox_sync_states.fan_page_id > fan_pages.id [delete: cascade]

// OpenAI Integration Relationships
Ref: openai_conversation.user_id > users.id
Ref: openai_conversation.current_branch_id > openai_conversation_branch.id [delete: set null]
Ref: openai_message.conversation_id > openai_conversation.id [delete: cascade]
Ref: openai_conversation_branch.conversation_id > openai_conversation.id [delete: cascade]
Ref: openai_conversation_branch.created_from_message_id > openai_message.id [delete: set null]
Ref: openai_conversation_branch.created_from_branch_id > openai_conversation_branch.id [delete: set null]
Ref: openai_response.user_id > users.id
Ref: openai_response.conversation_id > openai_conversation.id [delete: set null]
Ref: openai_response.branch_id > openai_conversation_branch.id [delete: set null]
Ref: openai_response.user_api_key_id > user_api_keys.id [delete: set null]
Ref: openai_response.agent_response_id > agent_response.id [delete: set null]
Ref: openai_branch_message_mapping.message_id > openai_message.id [delete: cascade]
Ref: openai_branch_message_mapping.branch_id > openai_conversation_branch.id [delete: cascade]
Ref: agent_response.user_id > users.id
Ref: agent_response.conversation_id > openai_conversation.id [delete: cascade]
Ref: agent_response.branch_id > openai_conversation_branch.id [delete: cascade]
Ref: agent_response.user_api_key_id > user_api_keys.id [delete: set null]

// Suggest Response & Memory Relationships
Ref: suggest_response_agent.user_id > users.id [delete: cascade]
Ref: page_memory.fan_page_id > fan_pages.id [delete: cascade]
Ref: page_memory.owner_user_id > users.id [delete: cascade]
Ref: page_scope_user_memory.fan_page_id > fan_pages.id [delete: cascade]
Ref: page_scope_user_memory.facebook_page_scope_user_id > facebook_page_scope_users.id [delete: cascade]
Ref: page_scope_user_memory.owner_user_id > users.id [delete: cascade]
Ref: user_memory.owner_user_id > users.id [delete: cascade]
Ref: suggest_response_history.user_id > users.id [delete: cascade]
Ref: suggest_response_history.fan_page_id > fan_pages.id [delete: cascade]
Ref: suggest_response_history.facebook_conversation_messages_id > facebook_conversation_messages.id [delete: set null]
Ref: suggest_response_history.facebook_conversation_comments_id > facebook_conversation_comments.id [delete: set null]
Ref: suggest_response_history.page_prompt_id > page_memory.id [delete: restrict]
Ref: suggest_response_history.page_scope_user_prompt_id > page_scope_user_memory.id [delete: restrict]
Ref: suggest_response_history.agent_response_id > agent_response.id [delete: restrict]

