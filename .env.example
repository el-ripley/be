# LLM API Keys
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# Proxy API Settings (Anthropic via proxy, optional)
ANTHROPIC_API_KEY_PROXY=your_anthropic_proxy_key_here
SUPPER_API_BASE_URL=http://your-proxy-host

# Google Cloud (Vertex AI, optional - alternative to GOOGLE_API_KEY)
GOOGLE_APPLICATION_CREDENTIALS=.gcp/sa.json
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_VERTEX_MODEL=gemini-2.5-pro

# Application Settings
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
BACKEND_URL=https://your-backend-url.ngrok-free.app
ALLOWED_FRONTEND_URLS=http://localhost:3000,https://yourdomain.com

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption Key (generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))")
ENCRYPTION_KEY=your_encryption_key_here

# Facebook App Configuration
FB_GRAPH_VERSION=v23.0
FB_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
FB_APP_ID=your_facebook_app_id
FB_APP_SECRET=your_facebook_app_secret

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5434
POSTGRES_USER=el-ripley-user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_SSL_MODE=disable
POSTGRES_DB_NAME=el_ripley
POSTGRES_AGENT_READER_USER=agent_reader
POSTGRES_AGENT_READER_PASSWORD=your_agent_reader_password
POSTGRES_AGENT_WRITER_USER=agent_writer
POSTGRES_AGENT_WRITER_PASSWORD=your_agent_writer_password
POSTGRES_SUGGEST_RESPONSE_READER_USER=suggest_response_reader
POSTGRES_SUGGEST_RESPONSE_READER_PASSWORD=your_suggest_reader_password
POSTGRES_SUGGEST_RESPONSE_WRITER_USER=suggest_response_writer
POSTGRES_SUGGEST_RESPONSE_WRITER_PASSWORD=your_suggest_writer_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=el-ripley

# MongoDB
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=your_mongodb_password
MONGODB_DB_NAME=ai_agent_db

# Qdrant (Vector DB)
QDRANT_HOST=localhost
QDRANT_PORT_REST=6333
QDRANT_PORT_GRPC=6334

# AWS S3
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=ap-southeast-2
AWS_BUCKET_NAME=your_s3_bucket_name

# Stripe (Payment)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# Sepay (Vietnam Payment)
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key

# Polar (Payment Gateway)
POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=polar_oat_your_access_token
POLAR_WEBHOOK_SECRET=polar_whs_your_webhook_secret
POLAR_PRODUCT_ID=your_polar_product_id
